# Telegram Bot Token from @BotFather
BOT_TOKEN=

# Admin IDs (comma-separated Telegram user IDs)
ADMIN_IDS=

# Database URL (SQLite by default, can use PostgreSQL for production)
DATABASE_URL=sqlite:///spy_game.db
# For PostgreSQL: postgresql://user:password@localhost/spy_game

# Web App URL (your domain where webapp is hosted)
WEBAPP_URL=https://modelling-dress-promises-annotated.trycloudflare.com

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
SECRET_KEY=your-secret-key-change-this-in-production

# Game Settings
MIN_PLAYERS=3
MAX_PLAYERS=10
GAME_DURATION=300
